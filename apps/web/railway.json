{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "apps/web/Dockerfile",
    "watchPatterns": ["**", "!/apps/**", "/apps/web/**"]
  },
  "deploy": {
    "numReplicas": 1,
    "healthcheck": {
      "type": "HTTP",
      "path": "/",
      "timeout": 300
    }
  }
}
